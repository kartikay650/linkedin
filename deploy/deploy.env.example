# Deploy tokens — copy this file to deploy/deploy.env and paste real values there.
# deploy/deploy.env is gitignored and never committed.
#
# I only need the three tokens below. Your app secrets (ANTHROPIC_API_KEY,
# APIFY_TOKEN, APIFY_WEBHOOK_SECRET, etc.) are already in the repo's .env and I'll
# reuse them for the Vercel environment — no need to re-paste those.

# GitHub personal access token with "repo" scope (to create a PRIVATE repo + push).
GITHUB_TOKEN=
GITHUB_USER=kartikay650
GITHUB_REPO=linkedin-engagement-dashboard

# Supabase personal/access token (Account → Access Tokens) — to create the NEW project.
SUPABASE_ACCESS_TOKEN=

# Vercel personal token (Account → Settings → Tokens) — to create the two projects + deploy.
VERCEL_TOKEN=
