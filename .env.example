# App environment. Locally this file is copied to .env (gitignored). On Vercel,
# set these as Project → Settings → Environment Variables (do NOT commit real values).

# --- Database (Supabase) ---
# Use Supabase's TRANSACTION POOLER url (port 6543) for serverless.
DATABASE_URL=postgresql://postgres.<ref>:<db-password>@aws-<region>.pooler.supabase.com:6543/postgres
SERVERLESS=true

# --- Supabase Storage (uploaded client docs) ---
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_KEY=<service-role-key>
SUPABASE_DOCS_BUCKET=client-docs

# --- LLM ---
ANTHROPIC_API_KEY=
RELEVANCE_MODEL=claude-haiku-4-5-20251001
DRAFT_MODEL=claude-sonnet-5

# --- Apify (post fetching + creator link resolution) ---
POSTS_PROVIDER=apify
APIFY_TOKEN=
APIFY_ACTOR_ID=harvestapi/linkedin-profile-posts
APIFY_INPUT_JSON={"targetUrls": ["{url}"], "maxPosts": {limit}}
APIFY_SEARCH_ACTOR_ID=apify/google-search-scraper

# --- Apify webhooks (serverless: fire-and-callback instead of polling) ---
APIFY_USE_WEBHOOKS=true
PUBLIC_BASE_URL=https://<your-backend>.vercel.app
APIFY_WEBHOOK_SECRET=<random-secret>

# --- Dashboard auth (frontend) ---
# On Vercel, protect the frontend project with Vercel password protection or Supabase Auth.
